{
  "version": 2,
  "framework": null,
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
  "installCommand": "pip install -r requirements.txt",
  "outputDirectory": null,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ],
  "functions": {
    "app/main.py": {
      "runtime": "python3.11",
      "maxDuration": 60
    }
  }
}