# ===========================================
# Email Service Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================

# Application
APP_NAME="Email Microservice"
DEBUG=false
API_KEY=your-super-secret-api-key-here-change-me-in-prod

# SMTP Configuration (Production-grade settings)
# Common providers:
# - Gmail: smtp.gmail.com:587 (use App Password, STARTTLS)
# - Mailtrap (testing): sandbox.smtp.mailtrap.io
# - Amazon SES, SendGrid, Mailgun, Postmark, etc. via their SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=pawan.dev.630703@gmail.com
SMTP_PASSWORD=msfmgagmtrgqipxr
SMTP_FROM_EMAIL=noreply@support.com
SMTP_FROM_NAME="Zoom Dance Studio"
SMTP_USE_TLS=true          # STARTTLS for port 587
SMTP_USE_SSL=false         # Implicit TLS for port 465 (set true and port=465 if needed)

# Optional: Default reply-to
DEFAULT_REPLY_TO=

# Security / CORS (comma separated origins, use * cautiously in prod)
CORS_ORIGINS=http://localhost:3000,https://yourapp.com

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO